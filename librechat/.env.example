# Public host (must match ACM SAN + DNS)
DOMAIN=librechat.ntwtech.com
DOMAIN_CLIENT=https://librechat.ntwtech.com
DOMAIN_SERVER=https://librechat.ntwtech.com

# Crypto (generate: openssl rand -hex 32 / openssl rand -hex 16 for CREDS_IV)
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=
MEILI_MASTER_KEY=

# Mongo (from make -C ../mongo conninfo) — database LibreChat is created on first use
MONGO_URI=mongodb://librechat:CHANGE_ME@mongo.mongo.svc.cluster.local:27017/LibreChat?authSource=admin

# Redis (from make -C ../redis conninfo)
REDIS_URI=redis://:CHANGE_ME@redis.redis.svc.cluster.local:6379/0

# Postgres RAG / pgvector (optional; RAG API disabled while using Groq)
POSTGRES_HOST=postgres.postgres.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=librechat_vectordb
POSTGRES_USER=librechat
POSTGRES_PASSWORD=poc-change-me-postgres

# S3 (from make -C ../s3 create-user)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=librechat-media-core-cluster

# Groq (https://console.groq.com/keys) — LibreChat expands ${GROQ_API_KEY} from the pod Secret
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Chart also expects OPENAI_API_KEY in the Secret; reuse Groq key
OPENAI_API_KEY=

# Optional registration
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true
