# Must match EKS (see eks/makefile CLUSTER_NAME)
CLUSTER_NAME=core-cluster
REGION=us-east-1

# Helm release namespace (controller runs here)
NAMESPACE=kube-system

# Optional: pin VPC if IMDS is restricted on nodes (auto-detected when empty)
# VPC_ID=vpc-xxxxxxxx

# ACM certificate for Unpod HTTPS hosts (*.unpod.ntwtech.com or multi-SAN)
# Used by: make -C ../unpod deploy (via ../ingress/.env)
# ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT:certificate/ID

# Public domain used only by `make endpoints` hints (Unpod owns the Ingress rules)
DOMAIN=unpod.ntwtech.com
