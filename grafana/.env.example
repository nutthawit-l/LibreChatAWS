# Grafana Cloud → Connections → Kubernetes / or stack settings
# Cluster name must match EKS (see eks/makefile CLUSTER_NAME)
CLUSTER_NAME=core-cluster

# Helm release namespace on the cluster
NAMESPACE=grafana

# --- Metrics (Prometheus remote write) ---
# Portal: Grafana Cloud → Prometheus → Details → Remote Write Endpoint
GRAFANA_CLOUD_METRICS_URL=https://prometheus-prod-XX-prod-XX-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_METRICS_USER=123456

# --- Logs (Loki) ---
# Portal: Grafana Cloud → Loki → Details → URL (+ /loki/api/v1/push)
GRAFANA_CLOUD_LOGS_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOGS_USER=123456

# --- Traces / OTLP (optional but enabled for LibreChat app telemetry) ---
# Portal: Grafana Cloud → OpenTelemetry → OTLP Endpoint (base URL, usually ends with /otlp)
GRAFANA_CLOUD_OTLP_URL=https://otlp-gateway-prod-XX-XX.grafana.net/otlp
# Stack / instance ID (same number shown next to your stack name)
GRAFANA_CLOUD_OTLP_INSTANCE_ID=123456

# Access policy token with scopes:
#   metrics:write  logs:write  traces:write  (and profiles:write if you enable profiling later)
# Create under: Grafana Cloud → Access policies
GRAFANA_CLOUD_TOKEN=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
