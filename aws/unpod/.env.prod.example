# Copy to .env.prod and fill real values before: make secrets
# Managed data stores should be reachable from EKS (same VPC / SG).

# --- Django / core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.unpod.example.com,localhost
BASE_URL=https://api.unpod.example.com
BASE_FRONTEND_URL=https://app.unpod.example.com

# --- Postgres (RDS) ---
DB_ENGINE=django.db.backends.postgresql
POSTGRES_DB=unpod_db
POSTGRES_USER=unpod
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=unpod.xxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432

# --- Mongo (DocumentDB / Atlas) ---
MONGO_DB=messaging_service
MONGO_DSN=mongodb://unpod:change-me@docdb.xxxxx.us-east-1.docdb.amazonaws.com:27017/messaging_service?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false

# --- Redis (ElastiCache) ---
REDIS_URL=redis://unpod.xxxxx.cache.amazonaws.com:6379/0
REDIS_URI=redis://unpod.xxxxx.cache.amazonaws.com:6379/0

# --- Internal service URLs (in-cluster DNS) ---
MESSAGING_SERVICE_URL=http://api-services:9116
STORE_SERVICE_URL=http://api-services:9116
SUPERBOOK_SERVICE_URL=http://api-services:9116
TASK_SERVICE_URL=http://api-services:9116

# --- Centrifugo ---
CENTRIFUGO_ENABLED=true
CENTRIFUGO_URL=http://centrifugo:8000/api
CENTRIFUGO_WS_URL=wss://realtime.unpod.example.com/connection/websocket
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key
CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=change-me-centrifugo-hmac

# --- S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=unpod-media-core-cluster
AWS_S3_REGION_NAME=us-east-1

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- AI providers (STT/TTS/cloud LLMs; optional if using self-hosted vLLM for chat) ---
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
GROQ_API_KEY=

# --- Self-hosted LLM (vLLM on gpu-pool) ---
# After: make deploy-llm
OPENAI_BASE_URL=http://vllm.unpod.svc.cluster.local:8000/v1
OPENAI_API_BASE=http://vllm.unpod.svc.cluster.local:8000/v1
OPENAI_API_KEY=local-vllm
VLLM_API_KEY=local-vllm
# Hugging Face token (required for gated models e.g. Llama; optional for Qwen)
HF_TOKEN=
# Model id clients should request (matches --served-model-name)
LLM_MODEL=local-llm

# --- Optional ---
SENDGRID_API_KEY=
RAZORPAY_KEY=
RAZORPAY_SECRET=
SIP_OUTBOUND_TRUNK_ID=

# --- Frontend (also used by web Deployment env) ---
# Set public URLs that browsers will call
PUBLIC_API_URL=https://api.unpod.example.com/api/v1/
PUBLIC_SITE_URL=https://app.unpod.example.com
PUBLIC_CHAT_WS_URL=wss://api.unpod.example.com/ws/v1/
